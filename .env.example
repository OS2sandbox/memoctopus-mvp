# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=memoctopus

# vLLM Configuration
VLLM_MODEL=Qwen/Qwen3-0.6B
# Optional: API key if your vLLM instance requires authentication
VLLM_API_KEY=

# STT (Speech-to-Text) Model
STT_MODEL=nvidia/parakeet-rnnt-110m-da-dk

# Hugging Face Token (required for vLLM and speaker diarization)
# Must accept conditions at https://huggingface.co/pyannote/speaker-diarization-community-1
HF_TOKEN=

# Frontend Configuration (optional - defaults work for Docker)
# BACKEND_URL is used for Next.js proxy, defaults to http://backend:8000 in Docker
# For local development without Docker, set BACKEND_URL=http://localhost:8002

# Better Auth Configuration
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your_better_auth_secret_here
BETTER_AUTH_URL=http://localhost:3000

# OAuth Configuration (optional)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
