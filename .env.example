# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=memoctopus

# vLLM Configuration
VLLM_MODEL=Qwen/Qwen3-0.6B
# Optional: API key if your vLLM instance requires authentication
VLLM_API_KEY=

# STT (Speech-to-Text) Model
STT_MODEL=nvidia/parakeet-rnnt-110m-da-dk

# Hugging Face Token (required for vLLM and speaker diarization)
# Must accept conditions at https://huggingface.co/pyannote/speaker-diarization-community-1
HF_TOKEN=

# Frontend Configuration (optional - defaults work for Docker)
# BACKEND_URL is used for Next.js proxy, defaults to http://backend:8000 in Docker
# For local development without Docker, set BACKEND_URL=http://localhost:8002

# Better Auth Configuration
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your_better_auth_secret_here
BETTER_AUTH_URL=http://localhost:3000
# Comma-separated list of trusted origins for Better Auth.
# Defaults to http://localhost:3000,http://127.0.0.1:3000 if unset.
# Add your own deployment's public hostnames here.
TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Auth method toggles
# Each provider has an explicit on/off switch. Defaults preserve current behavior:
#   email/password: on
#   Microsoft:      on (still requires creds below)
#   Authentik:      off (must be set to "true" to enable, also requires creds)
# Set to "false" to disable a provider on both the sign-in UI and the server.
# NEXT_PUBLIC_* values are baked in at frontend build time — rebuild the
# frontend image after changing them.
NEXT_PUBLIC_EMAIL_PASSWORD_ENABLED=true
NEXT_PUBLIC_MICROSOFT_ENABLED=true
NEXT_PUBLIC_AUTHENTIK_ENABLED=

# Microsoft OAuth (optional)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Authentik OIDC (optional)
# Create an OAuth2/OpenID provider + Application in your Authentik instance.
# Redirect URI to configure in Authentik:
#   <BETTER_AUTH_URL>/api/auth/oauth2/callback/authentik
# Discovery URL pattern:
#   https://<your-authentik-host>/application/o/<your-app-slug>/.well-known/openid-configuration
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_DISCOVERY_URL=
